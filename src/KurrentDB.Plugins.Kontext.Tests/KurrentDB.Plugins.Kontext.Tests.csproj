<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<IsKurrentTUnit>true</IsKurrentTUnit>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<IsPackable>false</IsPackable>
		<IsTestProject>true</IsTestProject>
		<EnablePreviewFeatures>true</EnablePreviewFeatures>
		<TreatWarningsAsErrors>false</TreatWarningsAsErrors>
		<NoWarn>$(NoWarn);NU1904</NoWarn>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="Microsoft.AspNetCore.TestHost" />
		<PackageReference Include="Shouldly" />
		<PackageReference Include="System.Linq.Async">
			<ExcludeAssets>compile</ExcludeAssets>
		</PackageReference>
	</ItemGroup>

	<ItemGroup>
		<Using Include="Shouldly" />
		<Using Include="TUnit" />
		<Using Include="TUnit.Core" />
		<Using Include="KurrentDB.Testing" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\KurrentDB.Testing.ClusterVNodeApp\KurrentDB.Testing.ClusterVNodeApp.csproj" />
		<ProjectReference Include="..\KurrentDB.Testing\KurrentDB.Testing.csproj" />
		<ProjectReference Include="..\KurrentDB.Plugins.Kontext\KurrentDB.Plugins.Kontext.csproj" />
	</ItemGroup>

</Project>
