@page "/ui/cluster"
@using KurrentDB.Common.Utils
@using KurrentDB.Components.Cluster.Monitoring
@using KurrentDB.Components.Licensed
@using KurrentDB.Core.Data
@using KurrentDB.Tools
@using KurrentDB.UI.Theme
@using Microsoft.AspNetCore.Authorization
@inherits KurrentDB.Components.Licensed.WithLicense
@attribute [Authorize]
@inject MetricsObserver MetricsObserver

<PageTitle>KurrentDB: Cluster</PageTitle>

<MudGrid>
	<MudItem xs="12">
		<MudDivider/>
		<MudStack Row="true" AlignItems="AlignItems.Center" Class="pl-2 pt-2">
			<MudText Typo="Typo.h5">Node status</MudText>
			<MudSpacer/>
			@if (IsCluster && LocalNode?.State == VNodeState.Leader) {
				<MudTooltip Text="You do not have the required permission" Disabled="@_canResign">
					<MudButton Variant="Variant.Outlined" Size="Size.Small"
					           StartIcon="@KurrentIcons.SignOut"
					           OnClick="ResignNode" Class="mr-2" Disabled="@(!_canResign)">Resign</MudButton>
				</MudTooltip>
			}
			<MudTooltip Text="You do not have the required permission" Disabled="@_canShutdown">
				<MudButton Variant="Variant.Outlined" Size="Size.Small"
				           StartIcon="@KurrentIcons.PowerOff"
				           OnClick="ShutdownServer" Disabled="@(!_canShutdown)">Shutdown</MudButton>
			</MudTooltip>
		</MudStack>
	</MudItem>
	<MudItem xs="12">
		<MudCard Class="ma-2">
			<MudCardHeader>
				<CardHeaderAvatar>
					<MudAvatar Color="@ClusterIconColor">
						<MudIcon Icon="@ClusterIcon"/>
					</MudAvatar>
				</CardHeaderAvatar>
				<CardHeaderContent>
					<MudText Typo="Typo.body1">
						Server address: @_clusterInfo?.ServerIp:@_clusterInfo?.ServerPort
					</MudText>
				</CardHeaderContent>
				<CardHeaderActions>
				</CardHeaderActions>
			</MudCardHeader>
			<MudCardContent>
				<MudText>Version: @VersionInfo.Text</MudText>
				<MudText>OS: @LocalOs</MudText>
			</MudCardContent>
		</MudCard>
	</MudItem>
	<MudItem xs="12">
		<MudDivider/>
		<MudText Typo="Typo.h5" Class="pt-2 pl-2">Cluster status</MudText>
	</MudItem>
	@foreach (var member in _clusterInfo?.Members ?? []) {
		<MudItem @key="(member.HttpEndPointIp, member.HttpEndPointPort)" Style="flex: 0 0 500px;">
			<ClusterMember Member="member" IsLocal="IsLocalNode(member)"/>
		</MudItem>
	}
	<MudItem xs="12">
		<MudDivider/>
		<MudText Typo="Typo.h5" Class="pt-2 pl-2">Resources</MudText>
	</MudItem>
	<MudItem Style="flex: 0 0 300px;" Class="d-flex flex-column">
		<MudPaper Class="pa-4 ma-2 d-flex flex-column justify-center align-center flex-grow-1" Outlined="true">
			<div class="mud-chart mud-chart-legend-bottom">
				<MudText Typo="Typo.h3" Align="Align.Center" Color="Color.Primary">
					@MetricsObserver.ActiveConnections
				</MudText>
				<div class="mud-chart-legend">
					<div class="mud-chart-legend-item">
						<span class="mud-typography mud-typography-body2">Connections</span>
					</div>
				</div>
			</div>
		</MudPaper>
	</MudItem>
	<MudItem Style="flex: 0 0 300px;">
		<MetricDonut Value="@_cpu" Name="CPU"></MetricDonut>
	</MudItem>
	<MudItem Style="flex: 0 0 300px;">
		<MetricDonut Value="@_ram" Name="Memory"></MetricDonut>
	</MudItem>
	<MudItem Style="flex: 0 0 300px;">
		<MetricDonut Value="@_disk" Name="Disk"></MetricDonut>
	</MudItem>
	<LicensedContent>
		<MudItem xs="6">
			<MudPaper Outlined="true">
				<MudTimeSeriesChart
					ChartSeries="@_cpuSeries"
					@bind-SelectedIndex="_index"
					Width="100%"
					Height="350px"
					ChartOptions="@_options"
					TimeLabelSpacing="TimeSpan.FromMinutes(5)"/>
			</MudPaper>
		</MudItem>
		<MudItem xs="6">
			<MudPaper Outlined="true">
				<MudTimeSeriesChart
					ChartSeries="@_ramSeries"
					@bind-SelectedIndex="_index"
					Width="100%"
					Height="350px"
					ChartOptions="@_options"
					TimeLabelSpacing="TimeSpan.FromMinutes(5)"/>
			</MudPaper>
		</MudItem>
	</LicensedContent>
	<LicensedContent>
		<MudItem xs="12">
			<MudDivider/>
			<MudText Typo="Typo.h5" Class="pt-2 pl-2">Throughput</MudText>
		</MudItem>
		<MudItem xs="6">
			<MudPaper Outlined="true">
				<MudTimeSeriesChart
					ChartSeries="@_eventsSeries"
					@bind-SelectedIndex="_index"
					Width="100%"
					Height="350px"
					ChartOptions="@_options"
					CanHideSeries
					TimeLabelSpacing="TimeSpan.FromMinutes(5)"/>
			</MudPaper>
		</MudItem>
		<MudItem xs="6">
			<MudPaper Outlined="true">
				<MudTimeSeriesChart
					ChartSeries="@_eventBytesSeries"
					@bind-SelectedIndex="_index"
					Width="100%"
					Height="350px"
					ChartOptions="@_options"
					CanHideSeries
					TimeLabelSpacing="TimeSpan.FromMinutes(5)"/>
			</MudPaper>
		</MudItem>
	</LicensedContent>
</MudGrid>
