@using KurrentDB.Services
@inject ClipboardService Clipboard
@inject ISnackbar Snackbar

<MudDialog>
	<TitleContent>
		<MudText Typo="Typo.h6">Dashboard Snapshot</MudText>
	</TitleContent>
	<DialogContent>
		<MudPaper Class="pa-4" Outlined="true" Style="max-height: 60vh; overflow: auto;">
			<pre style="margin: 0; font-family: monospace; white-space: pre;">@Snapshot</pre>
		</MudPaper>
	</DialogContent>
	<DialogActions>
		<MudButton OnClick="Cancel">Close</MudButton>
		<MudButton OnClick="Copy" Variant="Variant.Outlined">Copy to Clipboard</MudButton>
	</DialogActions>
</MudDialog>

@code {
	[CascadingParameter] private IMudDialogInstance MudDialog { get; set; }
	[Parameter] public string Snapshot { get; set; } = "";

	void Cancel() => MudDialog.Cancel();

	async Task Copy() {
		await Clipboard.WriteTextAsync(Snapshot);
		Snackbar.Add("Snapshot copied to clipboard.", Severity.Success);
	}
}
