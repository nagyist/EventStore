@inherits LayoutComponentBase
@using KurrentDB.UI.Theme

@* Minimal chrome for static auth pages (e.g. Login): no app bar / nav drawer (those live in the
   interactive MainLayout a static page can't drive). Light theme (the login screen is light) but with
   the brand rose as Primary so controls like the Sign In button aren't MudBlazor's default indigo. *@
<MudThemeProvider Theme="@Theme"/>
@Body

@code {
	static readonly MudTheme Theme = new() {
		PaletteLight = new() { Primary = KurrentTheme.Primary }
	};
}
