@inherits LayoutComponentBase
@implements IDisposable
@using KurrentDB.UI.Theme
@using KurrentDB.Components.ServerInfo
@using KurrentDB.Common.Utils
@inject KurrentDB.UI.Services.Preferences Preferences
@inject Microsoft.JSInterop.IJSRuntime JS

<MudThemeProvider Theme="@_theme" IsDarkMode="@Preferences.DarkMode"/>
@* Hosted once here now the layout is interactive (was per-page under the static-routing model). *@
<MudPopoverProvider/>
<MudDialogProvider/>
<MudSnackbarProvider/>
<MudLayout>
	<MudAppBar Elevation="1">
		<div style="display: flex; align-items: center; width: 240px;">
			<MudIconButton
				Icon="@Icons.Material.Filled.Menu"
				Color="Color.Inherit"
				Edge="Edge.Start"
				OnClick="@(() => _drawerOpen = !_drawerOpen)"/>
			<img alt="Kurrent logo" src="logo_white.svg" height="32"/>
		</div>
		<DatabaseInfoBadge/>
		<MudSpacer/>
		<KurrentDB.Components.Cluster.NodeStateIndicator/>
		<MudTooltip Text="@(Preferences.DarkMode ? "Switch to light theme" : "Switch to dark theme")">
			<MudIconButton
				Icon="@(Preferences.DarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
				Color="Color.Inherit"
				OnClick="ToggleTheme"/>
		</MudTooltip>
		<AuthorizeView>
			<Authorized>
				<MudText Typo="Typo.body2" Class="mr-2">@context.User.Identity?.Name</MudText>
				<MudIconButton Icon="@KurrentIcons.SignOut" Color="Color.Inherit" Href="/ui/logout"/>
			</Authorized>
		</AuthorizeView>
	</MudAppBar>
	<MudDrawer
		id="nav-drawer"
		@bind-Open="_drawerOpen"
		Elevation="1"
		Variant="@DrawerVariant.Responsive"
		Breakpoint="@Breakpoint.Md"
		ClipMode="DrawerClipMode.Always">
		<div class="d-flex flex-column" style="height: 100%;">
			<NavMenu/>
			<div class="mt-auto pa-3">
				<MudText Typo="Typo.caption" Style="opacity: 0.6;">KurrentDB @VersionInfo.Version</MudText>
			</div>
		</div>
	</MudDrawer>
	<MudMainContent Class="mt-16 pa-4">
		@Body
	</MudMainContent>
</MudLayout>

<div id="blazor-error-ui">
	An unhandled error has occurred.
	<a href="" class="reload">Reload</a>
	<a class="dismiss">🗙</a>
</div>

@code {
	bool _drawerOpen = true;
	MudTheme _theme = null!;

	protected override void OnInitialized() {
		base.OnInitialized();
		Preferences.ThemeChanged += OnThemeChanged;

		_theme = new() {
			PaletteLight = KurrentTheme.LightPalette,
			PaletteDark = KurrentTheme.DarkPalette,
			LayoutProperties = new(),
			Typography = new() {
				Default = new DefaultTypography {
					FontFamily = [
						"Solina",
						"-apple-system",
						"BlinkMacSystemFont",
						"Segoe UI",
						"Roboto",
						"Helvetica Neue",
						"Arial",
						"Noto Sans",
						"STHeiti",
						"Microsoft YaHei",
						"SimSun", "sans - serif", "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol", "Noto Color Emoji"
					]
				},
			}
		};
	}

	async Task ToggleTheme() {
		Preferences.ToggleTheme();
		// Persist to the cookie so the choice survives reloads (read back server-side on next render).
		await JS.InvokeVoidAsync("kurrentTheme.save", Preferences.DarkMode ? "dark" : "light");
	}

	// Re-render so MudThemeProvider picks up the new IsDarkMode (also covers toggles raised elsewhere).
	void OnThemeChanged(object sender, EventArgs e) => InvokeAsync(StateHasChanged);

	public void Dispose() => Preferences.ThemeChanged -= OnThemeChanged;
}
