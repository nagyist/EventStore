@inherits WithLicense

<PageTitle>KurrentDB: @PageName</PageTitle>

@if (HasLicense) {
	@Body
} else {
	<MudText>
		@PageName page requires a valid <MudLink Href="/ui/license">license</MudLink>.
	</MudText>
}

@code {
	protected abstract string PageName { get; }
	private protected virtual RenderFragment Body => null;
}
