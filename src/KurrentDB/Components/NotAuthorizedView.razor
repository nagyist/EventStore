@using System.Security.Claims

@* Rendered by Routes.razor's AuthorizeRouteView <NotAuthorized> fragment. The two cases must be
   distinguished: an authenticated user who simply lacks the operation sees an access-denied notice
   (logging in again as the same user wouldn't help), whereas an anonymous user is sent to the login
   form. Extracted from Routes.razor so the branch is unit-testable in isolation. *@
@if (User.Identity?.IsAuthenticated == true) {
	<MudAlert Severity="Severity.Error" Class="ma-4">You do not have access to this resource.</MudAlert>
} else {
	<RedirectToLogin/>
}

@code {
	[Parameter, EditorRequired] public ClaimsPrincipal User { get; set; } = default!;
}
