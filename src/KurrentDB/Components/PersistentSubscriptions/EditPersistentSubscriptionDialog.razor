@using System.Threading
@inject PersistentSubscriptionsService PersistentSubscriptionsService

<MudDialog>
	<TitleContent>
		<MudText Typo="Typo.h6">Edit Subscription: @GroupName on @StreamId</MudText>
	</TitleContent>
	<DialogContent>
		<MudForm @ref="_form" @bind-IsValid="_formValid" @bind-Errors="_errors">
			<MudTextField Value="StreamId" Label="Stream" Disabled="true"/>
			<MudTextField Value="GroupName" Label="Group Name" Disabled="true" Class="mb-4"/>

			<MudSelect T="string" @bind-Value="Config.NamedConsumerStrategy" Label="Consumer Strategy"
			           Variant="Variant.Outlined" Margin="Margin.Dense" Class="mt-2">
				<MudSelectItem Value="@("RoundRobin")">Round Robin</MudSelectItem>
				<MudSelectItem Value="@("DispatchToSingle")">Dispatch to Single</MudSelectItem>
				<MudSelectItem Value="@("Pinned")">Pinned</MudSelectItem>
				<MudSelectItem Value="@("PinnedByCorrelation")">Pinned by Correlation</MudSelectItem>
			</MudSelect>

			<MudNumericField @bind-Value="Config.StartFrom" Label="Start From" Class="mt-2"/>
			<MudCheckBox @bind-Value="Config.ResolveLinkTos" Label="Resolve Link Tos"/>
			<MudCheckBox @bind-Value="Config.ExtraStatistics" Label="Extra Statistics"/>
			<MudNumericField @bind-Value="Config.MessageTimeoutMilliseconds" Label="Message Timeout (ms)"/>
			<MudNumericField @bind-Value="Config.MaxRetryCount" Label="Max Retry Count"/>
			<MudNumericField @bind-Value="Config.LiveBufferSize" Label="Live Buffer Size"/>
			<MudNumericField @bind-Value="Config.BufferSize" Label="Buffer Size"/>
			<MudNumericField @bind-Value="Config.ReadBatchSize" Label="Read Batch Size"/>
			<MudNumericField @bind-Value="Config.CheckPointAfterMilliseconds" Label="Checkpoint After (ms)"/>
			<MudNumericField @bind-Value="Config.MinCheckPointCount" Label="Min Checkpoint Count"/>
			<MudNumericField @bind-Value="Config.MaxCheckPointCount" Label="Max Checkpoint Count"/>
			<MudNumericField @bind-Value="Config.MaxSubscriberCount" Label="Max Subscriber Count"/>
		</MudForm>
		@if (!string.IsNullOrEmpty(_serverError)) {
			<MudAlert Severity="Severity.Error" Class="mt-3">@_serverError</MudAlert>
		}
	</DialogContent>
	<DialogActions>
		<MudButton OnClick="Cancel" Disabled="@_saving">Cancel</MudButton>
		<MudButton OnClick="Submit" Variant="Variant.Outlined" Disabled="@_saving">Save</MudButton>
	</DialogActions>
</MudDialog>

@code {
	[CascadingParameter] private IMudDialogInstance MudDialog { get; set; }
	[CascadingParameter] Task<AuthenticationState> AuthenticationState { get; set; }

	[Parameter] public string StreamId { get; set; }
	[Parameter] public string GroupName { get; set; }
	[Parameter] public SubscriptionConfig Config { get; set; } = new();

	MudForm _form;
	bool _formValid;
	string[] _errors = [];
	bool _saving;
	string _serverError = "";

	void Cancel() => MudDialog.Cancel();

	async Task Submit() {
		await _form.Validate();
		if (!_formValid)
			return;

		_serverError = "";
		_saving = true;
		try {
			var principal = (await AuthenticationState).User;
			using var cts = new CancellationTokenSource(10000);
			await PersistentSubscriptionsService.UpdateAsync(principal, StreamId, GroupName, Config, cts.Token);
			MudDialog.Close(DialogResult.Ok(true));
		} catch (PersistentSubscriptionsException ex) {
			_serverError = ex.Message;
		} catch (Exception ex) {
			_serverError = ex.Message;
		} finally {
			_saving = false;
		}
	}
}
