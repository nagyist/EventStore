@page "/ui/plugins"
@attribute [Authorize(Policy = UiPolicies.ViewSubsystems)]
@using EventStore.Plugins
@using KurrentDB.Components.Shared
@using Microsoft.AspNetCore.Authorization
@inherits KurrentDB.Components.Licensed.LicensedPage
@inject PluginsService PluginsService

<MudStack Spacing="4">
	<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Style="width: 100%;">
		<MudText Typo="Typo.h5">Plugins</MudText>
		<MudSpacer/>
	</MudStack>

	<MudDataGrid Items="@PluginsService.PluggableComponents" Dense="true" Filterable="false">
		<Columns>
			<PropertyColumn Property="x => x.Name" Title="Subsystem"/>
			<PropertyColumn Property="x => x.Enabled" Title="Enabled"/>
			<PropertyColumn Property="x => x.Version" Title="Version"/>
		</Columns>
	</MudDataGrid>
</MudStack>

@code {
	protected override string PageName => "Subsystems";
}
