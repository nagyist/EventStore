<Router AppAssembly="typeof(App).Assembly">
	<Found Context="routeData">
		<AuthorizeRouteView RouteData="routeData" DefaultLayout="typeof(MainLayout)">
			<NotAuthorized>
				@* Authenticated-but-unauthorized → access denied; anonymous → login. With interactive
				   routing this fragment handles in-app navigations, so it must distinguish the two cases.
				   The branch lives in NotAuthorizedView so it can be unit-tested. *@
				<NotAuthorizedView User="context.User"/>
			</NotAuthorized>
		</AuthorizeRouteView>
		<FocusOnNavigate RouteData="routeData" Selector="h1"/>
	</Found>
</Router>
