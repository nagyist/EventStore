@page "/ui/preferences"
@attribute [Authorize(Policy = UiPolicies.EditServerInfo)]
@using KurrentDB.Components.Shared
@using Microsoft.AspNetCore.Authorization

<PageTitle>KurrentDB: Database Info</PageTitle>

<MudStack Spacing="4" Style="max-width: 600px;">
	<MudText Typo="Typo.h5">Database Info</MudText>

	@if (_loading) {
		<MudProgressLinear Indeterminate="true"/>
	} else {
		<MudPaper Class="pa-4" Outlined="true">
			<MudStack Spacing="3">
				<MudStack Spacing="1">
					<MudText Typo="Typo.h6">Name</MudText>
					<MudText Typo="Typo.body2">A friendly name for this database, shown in the top bar.</MudText>
				</MudStack>
				<MudTextField @bind-Value="_name" Placeholder="Name not set" Variant="Variant.Outlined"
				              Margin="Margin.Dense"/>

				<MudDivider Class="my-2"/>

				<MudStack Spacing="1">
					<MudText Typo="Typo.h6">Production</MudText>
					<MudText Typo="Typo.body2">When enabled, the top bar shows a PRODUCTION warning.</MudText>
				</MudStack>
				<MudSwitch Value="_production" Label="@(_production ? "Production" : "Non-production")"
				           Color="Color.Primary" Disabled="@_saving"
				           ValueChanged="(bool v) => _production = v" T="bool"/>

				<MudStack Row="true" Justify="Justify.FlexEnd" Class="mt-2">
					<MudButton Variant="Variant.Outlined" Color="Color.Primary"
					           OnClick="Save" Disabled="@_saving">Save</MudButton>
				</MudStack>
			</MudStack>
		</MudPaper>
	}
</MudStack>
