<MudDialog>
	<TitleContent>
		<MudText Typo="Typo.h6">Reset Password: @LoginName</MudText>
	</TitleContent>
	<DialogContent>
		<MudForm @ref="_form" @bind-IsValid="_formValid" @bind-Errors="_errors">
			<MudTextField @bind-Value="_model.NewPassword" Label="New Password"
			              InputType="InputType.Password"
			              Required="true" RequiredError="Password is required."/>
			<MudTextField @bind-Value="_model.ConfirmPassword" Label="Confirm Password"
			              InputType="InputType.Password"
			              Required="true"
			              Validation="@(new Func<string, string>(ValidatePasswordMatch))"/>
		</MudForm>
	</DialogContent>
	<DialogActions>
		<MudButton OnClick="Cancel">Cancel</MudButton>
		<MudButton OnClick="Submit"
		           Variant="Variant.Outlined" Color="Color.Primary">Reset Password</MudButton>
	</DialogActions>
</MudDialog>

@code {
	[CascadingParameter] private IMudDialogInstance MudDialog { get; set; }

	[Parameter] public string LoginName { get; set; }

	MudForm _form;
	bool _formValid;
	string[] _errors = [];
	readonly ResetPasswordModel _model = new();

	void Cancel() => MudDialog.Cancel();

	async Task Submit() {
		await _form.Validate();
		if (_formValid)
			MudDialog.Close(DialogResult.Ok(_model));
	}

	string ValidatePasswordMatch(string confirmPassword) =>
		_model.NewPassword != confirmPassword ? "Passwords do not match." : null;

	public class ResetPasswordModel {
		public string NewPassword { get; set; } = "";
		public string ConfirmPassword { get; set; } = "";
	}
}
